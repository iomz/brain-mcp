# Copy to .env and keep it out of git.
BRAIN_ROOT=/path/to/Brain
BRAIN_ROOT_HOST=/path/to/Brain
BRAIN_MCP_ADDR=127.0.0.1:8787
BRAIN_MCP_TOKEN=replace-me
BRAIN_MCP_WRITABLE_PATHS=Knowledge/,System/,Active/,Archive/
