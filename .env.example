# Copy to .env and keep it out of git.
BRAIN_ROOT=/path/to/Brain
BRAIN_ROOT_HOST=/path/to/Brain
BRAIN_MCP_ADDR=127.0.0.1:8787

# Auth mode: bearer, oauth, mixed, none
BRAIN_MCP_AUTH_MODE=mixed
BRAIN_MCP_TOKEN=replace-me

# OAuth protected resource
BRAIN_MCP_OAUTH_RESOURCE=https://brain.example.com/mcp

# Authentik issuer/discovery URL (provider slug INCLUDED)
BRAIN_MCP_OAUTH_ISSUER=https://auth.example.com/application/o/brain-mcp/
BRAIN_MCP_OAUTH_JWKS_URL=https://auth.example.com/application/o/brain-mcp/jwks/

# Authentik OAuth client
BRAIN_MCP_OAUTH_CLIENT_ID=<client-id>
BRAIN_MCP_OAUTH_ACCEPTED_AUDIENCES=https://brain.example.com/mcp,<client-id>

# Authorization server metadata advertised by brain-mcp
BRAIN_MCP_OAUTH_AUTHORIZATION_SERVER=https://auth.example.com/application/o/brain-mcp/
BRAIN_MCP_OAUTH_AUTHORIZATION_SERVERS=https://auth.example.com/application/o/brain-mcp/

# Experimental ChatGPT DCR support
BRAIN_MCP_OAUTH_DCR_ENABLED=false
BRAIN_MCP_OAUTH_AUTHORIZATION_SERVER_ISSUER=https://brain.example.com

BRAIN_MCP_OAUTH_APPROVAL_TOKEN=replace-with-local-approval-token
BRAIN_MCP_OAUTH_SUBJECT=brain-mcp-user
BRAIN_MCP_OAUTH_EMAIL=replace-me@example.com
BRAIN_MCP_OAUTH_STATE_FILE=.brain-mcp-oauth-state.json

# Optional Authentik-backed approval flow
BRAIN_MCP_OAUTH_AUTHENTIK_APPROVAL_ENABLED=false
BRAIN_MCP_OAUTH_AUTHENTIK_CLIENT_ID=<authentik-client-id>
BRAIN_MCP_OAUTH_AUTHENTIK_CLIENT_SECRET=

# IMPORTANT:
# Issuer/discovery URLs usually include the provider slug.
# Authorize/token endpoints commonly DO NOT.
# Verify using:
# curl -s https://auth.example.com/application/o/brain-mcp/.well-known/openid-configuration | jq
BRAIN_MCP_OAUTH_AUTHENTIK_AUTHORIZE_URL=https://auth.example.com/application/o/authorize/
BRAIN_MCP_OAUTH_AUTHENTIK_TOKEN_URL=https://auth.example.com/application/o/token/
BRAIN_MCP_OAUTH_AUTHENTIK_REDIRECT_URI=https://brain.example.com/oauth/authentik/callback

BRAIN_MCP_OAUTH_SCOPES=openid,email,profile,brain:read,brain:write,brain:git,brain:admin
BRAIN_MCP_OAUTH_DEFAULT_SCOPES=brain:read
BRAIN_MCP_BEARER_SCOPES=brain:read,brain:write,brain:git

BRAIN_MCP_ALLOWED_EMAILS=replace-me@example.com
BRAIN_MCP_ALLOWED_SUBJECTS=
BRAIN_MCP_ALLOWED_GROUPS=

BRAIN_MCP_AUTH_DEBUG=false

BRAIN_MCP_WRITABLE_PATHS=.
BRAIN_MCP_READONLY_PATHS=
BRAIN_MCP_REQUIRE_GIT=true

CLOUDFLARED_TUNNEL_TOKEN=replace-me
